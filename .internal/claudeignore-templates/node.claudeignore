# Node.js .claudeignore Template
# Copy this to .claudeignore in your project root to save tokens

# Dependencies
node_modules/
.pnp
.pnp.js

# Testing
coverage/
.nyc_output/

# Production / Build
dist/
build/
out/
.next/
.nuxt/
.vuepress/
.serverless/
.cache/
.vitepress/dist/
.output/

# Lock files (Claude rarely needs to read these 10k+ line files)
package-lock.json
yarn.lock
pnpm-lock.yaml
bun.lockb

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Environment and Secrets (Security)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem

# Misc
.DS_Store
*.tsbuildinfo
