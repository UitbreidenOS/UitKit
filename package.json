{
  "name": "claudient",
  "version": "1.1.0",
  "description": "The Claude Code knowledge system — installable plugin marketplace with 400+ skills, 182+ agents, 42 workspace stacks, 41 MCP configs, 100+ commands, 40 hooks, 32 rules, 10 routines, 100+ guides, 83 structures, output styles, themes, statuslines, keybindings, settings templates, and an Agent SDK pack in 5 languages. Features: matrix CLI tool, SVG inspector, swarm sandbox, and advanced CLI automation.",
  "keywords": [
    "claude-code",
    "claude",
    "anthropic",
    "llm",
    "ai-tools",
    "developer-productivity",
    "skills",
    "agents",
    "hooks",
    "gtm",
    "legal",
    "finance",
    "marketing",
    "small-business",
    "cloud-architecture",
    "compliance",
    "orchestration"
  ],
  "author": {
    "name": "tushar2704",
    "email": "ceo@uitbreiden.com",
    "url": "https://uitbreiden.com"
  },
  "homepage": "https://github.com/Claudient/Claudient",
  "repository": {
    "type": "git",
    "url": "https://github.com/Claudient/Claudient.git"
  },
  "license": "(AGPL-3.0-or-later AND CC-BY-SA-4.0)",
  "bin": {
    "claudient": "./scripts/cli.js"
  },
  "files": [
    "scripts/",
    "skills/",
    "agents/",
    "hooks/",
    "rules/",
    "workflows/",
    "prompts/",
    "mcp/",
    "guides/",
    "structures/",
    "professional-stacks/",
    "compatibility/",
    "claude-md-examples/",
    "plugins/",
    "commands/",
    "personas/",
    "output-styles/",
    "statuslines/",
    "themes/",
    "keybindings/",
    "settings-templates/",
    "routines/",
    "examples/",
    ".claude-plugin/",
    "CONTEXT.md",
    "README.md",
    "index.json"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "list": "node scripts/cli.js list",
    "matrix": "node scripts/matrix-cli.js",
    "svg-inspector": "node scripts/svg-inspector.js",
    "swarm-sandbox": "node scripts/swarm-sandbox.js",
    "theme-builder": "node scripts/theme-builder.js",
    "theme-builder-batch": "node scripts/theme-builder-batch.js",
    "contributor-onboarding": "node scripts/contributor-onboarding.js",
    "contributor-rewards": "node scripts/process-contributor-rewards.js",
    "community-events": "node scripts/community-events.js",
    "build-index": "node scripts/build-index.js",
    "build-plugins": "node scripts/build-plugins.js",
    "build-catalog": "node scripts/build-catalog.js",
    "add-frontmatter": "node scripts/add-frontmatter.js",
    "validate": "node scripts/validate-frontmatter.js && node scripts/validate-manifests.js",
    "validate:frontmatter": "node scripts/validate-frontmatter.js",
    "validate:manifests": "node scripts/validate-manifests.js",
    "validate:catalog": "node scripts/validate-catalog.js",
    "validate:freshness": "node scripts/check-freshness.js",
    "validate:stacks": "node scripts/validate-stacks.js",
    "backfill-dates": "node scripts/backfill-dates.js",
    "dep-graph": "node scripts/dependency-graph.js",
    "changelog": "node scripts/generate-changelog.js --write",
    "benchmark": "node scripts/generate-benchmarks.js",
    "knowledge-graph": "node scripts/knowledge-graph-cli.js",
    "kg:build": "node scripts/knowledge-graph-cli.js build",
    "kg:search": "node scripts/knowledge-graph-cli.js search",
    "kg:stats": "node scripts/knowledge-graph-cli.js stats",
    "kg:centrality": "node scripts/knowledge-graph-cli.js centrality",
    "kg:explore": "node scripts/knowledge-graph-cli.js explore",
    "test": "node scripts/test-cli.js",
    "test:contrib": "node scripts/contributor-onboarding.test.js",
    "test:regression": "node test/regression/backward-compatibility.test.js",
    "test:all": "npm run test && npm run test:regression",
    "add-descriptions": "node scripts/add-descriptions.js",
    "translate": "node scripts/translate-assets.js",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.0.11",
    "lint-staged": "^15.2.2",
    "sharp": "^0.35.1"
  },
  "lint-staged": {
    "*.md": [
      "npm run validate:frontmatter"
    ]
  }
}
