---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  ogImage?: string;
}

const {
  title,
  description = "The Claude Code knowledge base — 277+ skills, 95+ agents, 30+ hooks, 30+ MCP configs for Claude Code. Open source, multi-language, free to use.",
  canonical,
  jsonLd,
  ogImage: ogImageProp,
} = Astro.props;

const siteUrl = "https://claudient.tools";
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, siteUrl).href;

// Derive per-page SVG OG image from the canonical URL path.
// Pattern: /{collection}/{...slug}/ → /og/{collection}/{...slug}.svg
// Falls back to the static default for non-collection pages.
const DETAIL_COLLECTIONS = new Set([
  "skills", "agents", "hooks", "mcp", "workflows", "guides", "prompts", "rules",
]);
function deriveOgImage(url: string): string {
  try {
    const { pathname } = new URL(url);
    const parts = pathname.replace(/^\/|\/$/g, "").split("/").filter(Boolean);
    // Must have at least 2 segments: collection + slug
    if (parts.length >= 2 && DETAIL_COLLECTIONS.has(parts[0])) {
      return `${siteUrl}/og/${parts.join("/")}.svg`;
    }
  } catch {
    // malformed URL — fall through to default
  }
  return `${siteUrl}/og-default.png`;
}

const ogImage = ogImageProp ?? deriveOgImage(canonicalUrl);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="Claudient" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#fafaf9" />

    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}
  </head>
  <body class="min-h-screen flex flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
