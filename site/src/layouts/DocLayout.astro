---
import Layout from "./Layout.astro";
import { slugToTitle } from "../lib/content";

interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  title: string;
  description?: string;
  collection: string;
  collectionLabel: string;
  category?: string;
  breadcrumbs?: BreadcrumbItem[];
  jsonLd?: Record<string, unknown>;
}

const { title, description, collection, collectionLabel, category, breadcrumbs, jsonLd } = Astro.props;

const crumbs: BreadcrumbItem[] = breadcrumbs ?? [
  { label: "Home", href: "/" },
  { label: collectionLabel, href: `/${collection}/` },
  ...(category
    ? [{ label: slugToTitle(category), href: `/${collection}/?category=${category}` }]
    : []),
  { label: title },
];
---

<Layout title={`${title} | Claudient`} description={description} jsonLd={jsonLd}>
  <article class="container-page py-10 md:py-14">
    <nav class="mb-6 text-sm flex items-center gap-2 flex-wrap" style="color: var(--color-muted);">
      {
        crumbs.map((crumb, i) => (
          <Fragment>
            {crumb.href ? (
              <a href={crumb.href} class="hover:underline" style={i === crumbs.length - 1 ? "color: var(--color-fg);" : ""}>
                {crumb.label}
              </a>
            ) : (
              <span style="color: var(--color-fg);">{crumb.label}</span>
            )}
            {i < crumbs.length - 1 && <span style="color: var(--color-subtle);">/</span>}
          </Fragment>
        ))
      }
    </nav>

    <header class="mb-8 pb-6 border-b" style="border-color: var(--color-border);">
      <div class="flex items-center gap-2 mb-3">
        <span class="pill">{collectionLabel}</span>
        {category && <span class="pill">{slugToTitle(category)}</span>}
      </div>
      <h1 class="text-3xl md:text-4xl font-semibold tracking-tight">{title}</h1>
      {description && (
        <p class="mt-3 text-lg max-w-2xl" style="color: var(--color-muted);">
          {description}
        </p>
      )}
    </header>

    <div class="prose">
      <slot />
    </div>
  </article>
</Layout>
