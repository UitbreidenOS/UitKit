---
import Layout from "./Layout.astro";
import { slugToTitle } from "../lib/content";
import type { TocHeading, RelatedEntry } from "../lib/content";

interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  title: string;
  description?: string;
  collection: string;
  collectionLabel: string;
  category?: string;
  breadcrumbs?: BreadcrumbItem[];
  jsonLd?: Record<string, unknown>;
  readingMinutes?: number;
  headings?: TocHeading[];
  related?: RelatedEntry[];
}

const { title, description, collection, collectionLabel, category, breadcrumbs, jsonLd, readingMinutes, headings, related } = Astro.props;

const crumbs: BreadcrumbItem[] = breadcrumbs ?? [
  { label: "Home", href: "/" },
  { label: collectionLabel, href: `/${collection}/` },
  ...(category
    ? [{ label: slugToTitle(category), href: `/${collection}/?category=${category}` }]
    : []),
  { label: title },
];

const showToc = headings && headings.length >= 4;
---

<Layout title={`${title} | Claudient`} description={description} jsonLd={jsonLd}>
  <div class={showToc ? "toc-layout container-page py-10 md:py-14" : ""}>
    {showToc && (
      <aside class="toc-sidebar">
        <nav class="toc-nav" aria-label="Table of contents">
          <p class="toc-label">On this page</p>
          <ul>
            {headings!.map((h) => (
              <li class={h.depth === 3 ? "toc-h3" : ""}>
                <a href={`#${h.slug}`}>{h.text}</a>
              </li>
            ))}
          </ul>
        </nav>
      </aside>
    )}

    <article class="container-page py-10 md:py-14" class:list={[showToc ? "toc-content" : ""]} data-pagefind-body>
      <nav class="mb-6 text-sm flex items-center gap-2 flex-wrap" style="color: var(--color-muted);">
        {
          crumbs.map((crumb, i) => (
            <Fragment>
              {crumb.href ? (
                <a href={crumb.href} class="hover:underline" style={i === crumbs.length - 1 ? "color: var(--color-fg);" : ""}>
                  {crumb.label}
                </a>
              ) : (
                <span style="color: var(--color-fg);">{crumb.label}</span>
              )}
              {i < crumbs.length - 1 && <span style="color: var(--color-subtle);">/</span>}
            </Fragment>
          ))
        }
      </nav>

      <header class="mb-8 pb-6 border-b" style="border-color: var(--color-border);">
        <div class="flex items-center gap-2 mb-3 flex-wrap">
          <span class="pill">{collectionLabel}</span>
          {category && <span class="pill">{slugToTitle(category)}</span>}
          {readingMinutes && <span class="pill">{readingMinutes} min read</span>}
        </div>
        <h1 class="text-3xl md:text-4xl font-semibold tracking-tight">{title}</h1>
        {description && (
          <p class="mt-3 text-lg max-w-2xl" style="color: var(--color-muted);">
            {description}
          </p>
        )}
      </header>

      <div class="prose">
        <slot />
      </div>

      <script is:inline>
        (function () {
          function initCodeBlocks() {
            var proseEl = document.querySelector('.prose');
            if (!proseEl) return;
            var pres = proseEl.querySelectorAll('pre');
            pres.forEach(function (pre) {
              // Skip if already enhanced
              if (pre.parentElement && pre.parentElement.classList.contains('code-block-wrapper')) return;

              // Wrap in relative-positioned div
              var wrapper = document.createElement('div');
              wrapper.className = 'code-block-wrapper';
              pre.parentNode.insertBefore(wrapper, pre);
              wrapper.appendChild(pre);

              // Language badge (top-left)
              var lang = pre.getAttribute('data-language');
              if (lang) {
                var badge = document.createElement('span');
                badge.className = 'code-lang-badge';
                badge.textContent = lang;
                wrapper.appendChild(badge);
              }

              // Copy button (top-right)
              var btn = document.createElement('button');
              btn.className = 'code-copy-btn';
              btn.setAttribute('aria-label', 'Copy code');
              btn.setAttribute('title', 'Copy code');
              btn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>';

              var checkSvg = '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>';
              var clipSvg = btn.innerHTML;

              btn.addEventListener('click', function () {
                var code = pre.querySelector('code');
                var text = code ? code.textContent : pre.textContent;
                if (!navigator.clipboard) return;
                navigator.clipboard.writeText(text).then(function () {
                  btn.innerHTML = checkSvg;
                  btn.setAttribute('title', 'Copied!');
                  setTimeout(function () {
                    btn.innerHTML = clipSvg;
                    btn.setAttribute('title', 'Copy code');
                  }, 2000);
                }).catch(function () {});
              });

              wrapper.appendChild(btn);
            });
          }

          if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', initCodeBlocks);
          } else {
            initCodeBlocks();
          }
        })();
      </script>

      {related && related.length > 0 && (
        <section class="mt-12 pt-8 border-t" style="border-color: var(--color-border);">
          <h2 class="text-xl font-semibold mb-6">Related</h2>
          <div class="related-grid">
            {related.map((item) => (
              <a href={item.url} class="card related-card">
                <p class="related-card-title">{item.title}</p>
                {item.description && (
                  <p class="related-card-desc">{item.description}</p>
                )}
              </a>
            ))}
          </div>
        </section>
      )}
    </article>
  </div>
</Layout>

<style>
  /* TOC layout — two-column on lg+ viewports */
  .toc-layout {
    display: flex;
    align-items: flex-start;
    gap: 2rem;
  }

  .toc-content {
    flex: 1;
    min-width: 0;
    /* override container-page centering inside the flex layout */
    max-width: 44rem;
    margin-inline: 0;
    padding-inline: 0;
  }

  .toc-sidebar {
    display: none;
  }

  @media (min-width: 1024px) {
    .toc-sidebar {
      display: block;
      position: sticky;
      top: 5rem;
      width: 14rem;
      flex-shrink: 0;
      order: 2;
    }
  }

  .toc-nav {
    font-size: 0.8125rem;
    line-height: 1.5;
  }

  .toc-label {
    font-weight: 600;
    font-size: 0.75rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-muted);
    margin-bottom: 0.75rem;
  }

  .toc-nav ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .toc-nav li a {
    display: block;
    color: var(--color-muted);
    text-decoration: none;
    padding: 0.2rem 0.5rem;
    border-radius: var(--radius-sm);
    transition: color 0.1s ease, background-color 0.1s ease;
  }

  .toc-nav li a:hover {
    color: var(--color-fg);
    background-color: var(--color-muted-bg);
  }

  .toc-nav li.toc-h3 a {
    padding-left: 1.25rem;
    font-size: 0.75rem;
  }

  /* Related section grid */
  .related-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  @media (min-width: 640px) {
    .related-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .related-card {
    display: block;
    padding: 1rem 1.25rem;
    text-decoration: none;
    color: inherit;
  }

  .related-card-title {
    font-weight: 600;
    font-size: 0.9375rem;
    margin: 0 0 0.375rem;
    color: var(--color-fg);
  }

  .related-card-desc {
    font-size: 0.8125rem;
    color: var(--color-muted);
    line-height: 1.5;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
