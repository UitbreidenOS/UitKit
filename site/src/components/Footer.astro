---
const year = new Date().getFullYear();
---

<footer class="border-t mt-24" style="border-color: var(--color-border);">

  <!-- Newsletter signup row -->
  <!-- TODO: replace USERNAME=claudient with the real Buttondown username once registered -->
  <div class="border-b" style="border-color: var(--color-border);">
    <div class="container-page py-10 flex flex-col sm:flex-row items-start sm:items-center gap-6">
      <div class="flex-1 min-w-0">
        <p class="font-semibold text-sm" style="color: var(--color-fg);">Stay up to date</p>
        <p class="text-sm mt-0.5" style="color: var(--color-muted);">
          Monthly newsletter. No spam. Unsubscribe anytime.
        </p>
      </div>
      <form
        action="https://buttondown.com/api/emails/embed-subscribe/claudient"
        method="post"
        target="_blank"
        class="flex gap-2 w-full sm:w-auto"
      >
        <input
          type="email"
          name="email"
          placeholder="you@example.com"
          required
          class="flex-1 sm:w-56 rounded-md border px-3 py-2 text-sm outline-none focus:ring-2"
          style="border-color: var(--color-border); background: var(--color-surface); color: var(--color-fg);"
        />
        <button
          type="submit"
          class="rounded-md px-4 py-2 text-sm font-medium text-white whitespace-nowrap"
          style="background-color: var(--color-accent);"
        >
          Subscribe
        </button>
      </form>
    </div>
  </div>

  <div class="container-page py-12 grid gap-8 md:grid-cols-4">
    <div class="md:col-span-2">
      <div class="flex items-center gap-2 font-semibold text-lg tracking-tight">
        <span
          class="inline-flex items-center justify-center w-7 h-7 rounded-md text-white font-bold text-sm"
          style="background-color: var(--color-accent);"
        >
          C
        </span>
        <span>Claudient</span>
      </div>
      <p class="mt-3 max-w-md text-sm" style="color: var(--color-muted);">
        The community knowledge base for Claude Code — skills, agents, hooks, MCP configs, workflows.
        Open source, multi-language, free to use.
      </p>
    </div>

    <div>
      <h3 class="text-sm font-semibold mb-3" style="color: var(--color-fg);">Browse</h3>
      <ul class="space-y-2 text-sm" style="color: var(--color-muted);">
        <li><a href="/skills/" class="hover:underline">Skills</a></li>
        <li><a href="/agents/" class="hover:underline">Agents</a></li>
        <li><a href="/hooks/" class="hover:underline">Hooks</a></li>
        <li><a href="/mcp/" class="hover:underline">MCP servers</a></li>
        <li><a href="/guides/" class="hover:underline">Guides</a></li>
      </ul>
    </div>

    <div>
      <h3 class="text-sm font-semibold mb-3" style="color: var(--color-fg);">Project</h3>
      <ul class="space-y-2 text-sm" style="color: var(--color-muted);">
        <li><a href="/about/" class="hover:underline">About</a></li>
        <li><a href="/contribute/" class="hover:underline">Contribute</a></li>
        <li><a href="https://github.com/Claudient/Claudient" target="_blank" rel="noopener" class="hover:underline">GitHub</a></li>
        <li><a href="https://www.npmjs.com/package/claudient" target="_blank" rel="noopener" class="hover:underline">npm</a></li>
      </ul>
    </div>
  </div>

  <div
    class="border-t py-6"
    style="border-color: var(--color-border);"
  >
    <div class="container-page flex flex-col sm:flex-row items-center justify-between gap-3 text-sm" style="color: var(--color-muted);">
      <p>© {year} Tushar Aggarwal. MIT licensed.</p>
      <p>
        Built by
        <a href="https://uitbreiden.com/" target="_blank" rel="noopener" class="hover:underline" style="color: var(--color-fg);">
          Uitbreiden
        </a>
      </p>
    </div>
  </div>
</footer>
