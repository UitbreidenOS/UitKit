---
const year = new Date().getFullYear();
---

<footer class="border-t mt-24" style="border-color: var(--color-border);">


  <div class="container-page py-12 grid gap-8 md:grid-cols-4">
    <div class="md:col-span-2">
      <div>
        <img src="/logo.png" alt="Claudient" height="32" class="h-8 w-auto" />
      </div>
      <p class="mt-3 max-w-md text-sm" style="color: var(--color-muted);">
        The community knowledge base for Claude Code — skills, agents, hooks, MCP configs, workflows.
        Open source, multi-language, free to use.
      </p>
    </div>

    <div>
      <h3 class="text-sm font-semibold mb-3" style="color: var(--color-fg);">Browse</h3>
      <ul class="space-y-2 text-sm" style="color: var(--color-muted);">
        <li><a href="/skills/" class="hover:underline">Skills</a></li>
        <li><a href="/agents/" class="hover:underline">Agents</a></li>
        <li><a href="/hooks/" class="hover:underline">Hooks</a></li>
        <li><a href="/mcp/" class="hover:underline">MCP servers</a></li>
        <li><a href="/guides/" class="hover:underline">Guides</a></li>
      </ul>
    </div>

    <div>
      <h3 class="text-sm font-semibold mb-3" style="color: var(--color-fg);">Project</h3>
      <ul class="space-y-2 text-sm" style="color: var(--color-muted);">
        <li><a href="/about/" class="hover:underline">About</a></li>
        <li><a href="/contribute/" class="hover:underline">Contribute</a></li>
        <li><a href="https://github.com/Claudient/Claudient" target="_blank" rel="noopener" class="hover:underline">GitHub</a></li>
        <li><a href="https://www.npmjs.com/package/claudient" target="_blank" rel="noopener" class="hover:underline">npm</a></li>
      </ul>
    </div>
  </div>

  <div
    class="border-t py-6"
    style="border-color: var(--color-border);"
  >
    <div class="container-page flex flex-col sm:flex-row items-center justify-between gap-3 text-sm" style="color: var(--color-muted);">
      <p>
        © {year}
        <a href="https://uitbreiden.com/" target="_blank" rel="noopener" class="hover:underline" style="color: var(--color-fg);">
          Uitbreiden
        </a>.
        Code <a href="https://github.com/Claudient/Claudient/blob/main/LICENSE-CODE" target="_blank" rel="noopener" class="hover:underline">AGPL-3.0</a> ·
        Content <a href="https://github.com/Claudient/Claudient/blob/main/LICENSE-CONTENT" target="_blank" rel="noopener" class="hover:underline">CC-BY-SA-4.0</a>.
      </p>
      <p>
        Built by
        <a href="https://uitbreiden.com/" target="_blank" rel="noopener" class="hover:underline" style="color: var(--color-fg);">
          Uitbreiden
        </a>
      </p>
    </div>
  </div>
</footer>
