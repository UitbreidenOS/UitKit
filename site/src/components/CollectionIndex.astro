---
import {
  groupByCategory,
  titleFromEntry,
  descriptionFromEntry,
  slugToTitle,
  urlForEntry,
} from "../lib/content";
import type { CollectionEntry, CollectionKey } from "astro:content";

interface Props {
  title: string;
  description: string;
  entries: CollectionEntry<CollectionKey>[];
  collection: string;
}

const { title, description, entries, collection } = Astro.props;
const grouped = groupByCategory(entries);
---

<section class="container-page py-10 md:py-14">
  <header class="mb-10 max-w-3xl">
    <h1 class="text-3xl md:text-5xl font-semibold tracking-tight">{title}</h1>
    <p class="mt-3 text-lg" style="color: var(--color-muted);">{description}</p>
    <p class="mt-2 text-sm" style="color: var(--color-subtle);">
      {entries.length} {entries.length === 1 ? "entry" : "entries"} · {grouped.length}{" "}
      {grouped.length === 1 ? "category" : "categories"}
    </p>
  </header>

  {
    grouped.map(({ category, entries: items }) => (
      <section class="mb-12" id={category}>
        <div class="flex items-baseline justify-between mb-4 pb-2 border-b" style="border-color: var(--color-border);">
          <h2 class="text-xl font-semibold tracking-tight">{slugToTitle(category)}</h2>
          <span class="text-sm" style="color: var(--color-muted);">{items.length}</span>
        </div>
        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
          {items.map((entry) => {
            const desc = descriptionFromEntry(entry, 110);
            return (
              <a href={urlForEntry(collection, entry)} class="card p-4 block group">
                <h3 class="font-medium text-base mb-1 group-hover:text-[var(--color-accent)] transition-colors">
                  {titleFromEntry(entry)}
                </h3>
                {desc && (
                  <p class="text-sm line-clamp-2" style="color: var(--color-muted);">
                    {desc}
                  </p>
                )}
              </a>
            );
          })}
        </div>
      </section>
    ))
  }
</section>
