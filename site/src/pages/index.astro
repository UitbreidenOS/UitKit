---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import { pathToParts, slugToTitle, titleFromEntry, descriptionFromEntry, urlForEntry } from "../lib/content";
import { popularSkills, popularAgents, popularMcp } from "../data/featured";

// Live counts: pull every English content file from the repo at build time
const [skills, agents, hooks, mcp, workflows, guides, prompts, rules] = await Promise.all([
  getCollection("skills", ({ data }) => !data.draft),
  getCollection("agents", ({ data }) => !data.draft),
  getCollection("hooks", ({ data }) => !data.draft),
  getCollection("mcp", ({ data }) => !data.draft),
  getCollection("workflows", ({ data }) => !data.draft),
  getCollection("guides", ({ data }) => !data.draft),
  getCollection("prompts", ({ data }) => !data.draft),
  getCollection("rules", ({ data }) => !data.draft),
]);

// Build category cards from real skill data — group by top-level folder
const skillsByCategory = new Map<string, number>();
for (const skill of skills) {
  const { category } = pathToParts(skill.id);
  skillsByCategory.set(category, (skillsByCategory.get(category) ?? 0) + 1);
}

// Hand-curated category descriptions; counts come from live data above.
// Categories not in this map still render with a generic description.
const categoryDescriptions: Record<string, string> = {
  "backend": "Next.js, FastAPI, Hono, NestJS, Rust, Go, Rails, Laravel, Elixir",
  "devops-infra": "Kubernetes, Terraform, Docker, GitHub Actions, Sentry, OpenTelemetry",
  "ai-engineering": "Claude API, LangGraph, RAG, prompt caching, batch API, MCP builder",
  "small-business": "Invoice chasing, dental, salon, ecommerce, coaching, newsletter, podcasts",
  "gtm": "HubSpot, SDR agent, lead enrichment, email automation, CRM hygiene",
  "legal": "Contract review, NDA, GDPR, SOC 2, EU AI Act, IP clearance",
  "finance": "DCF, 3-statement model, IC memo, pitch deck, KYC, GL reconciliation",
  "data-ml": "dbt, Spark, Kafka, MLOps, NLP pipelines, Pandas/Polars, PyTorch",
  "database": "Drizzle, Prisma, PostgreSQL, Supabase, Neon, Redis, Elasticsearch",
  "marketing": "SEO audit, AI SEO, programmatic SEO, paid ads, CRO, copywriting",
  "product": "Product discovery, experiment designer, competitive teardown, roadmap",
  "productivity": "Ship gate, PR review, ADR writer, tech debt tracker, context engineering",
  "automation": "Playwright Pro, browser automation, Remotion, SaaS scaffolder, office docs",
  "finance-payments": "Stripe, payment flows, subscriptions, refunds, webhooks",
};

const categories = [...skillsByCategory.entries()]
  .map(([slug, count]) => ({
    slug,
    name: slugToTitle(slug),
    count,
    description: categoryDescriptions[slug] ?? `${count} skills in this category`,
    href: `/skills/${slug}/`,
  }))
  .sort((a, b) => b.count - a.count)
  .slice(0, 8);

const stats = {
  skills: skills.length,
  agents: agents.length,
  hooks: hooks.length,
  mcp: mcp.length,
  workflows: workflows.length,
  guides: guides.length,
  prompts: prompts.length,
  rules: rules.length,
};
const totalItems = Object.values(stats).reduce((a, b) => a + b, 0);

// Resolve featured items from curated slug lists
function resolveFeatured(
  items: typeof popularSkills,
  collection: typeof skills | typeof agents | typeof mcp,
  collectionName: string,
) {
  return items.flatMap((item) => {
    const entry = collection.find(
      (e) => e.id.replace(/\.md$/, "") === item.slug,
    );
    if (!entry) return [];
    const title = item.override?.title ?? titleFromEntry(entry);
    const description = item.override?.description ?? descriptionFromEntry(entry);
    const href = urlForEntry(collectionName, entry);
    return [{ title, description, href }];
  });
}

const featuredSkills = resolveFeatured(popularSkills, skills, "skills");
const featuredAgents = resolveFeatured(popularAgents, agents, "agents");
const featuredMcp = resolveFeatured(popularMcp, mcp, "mcp");

const claudeForVerticals = [
  { label: "Solopreneurs", href: "/claude-for/solopreneurs/" },
  { label: "Ecommerce", href: "/claude-for/ecommerce/" },
  { label: "Local services", href: "/claude-for/local-services/" },
  { label: "Coaches & consultants", href: "/claude-for/coaches-consultants/" },
  { label: "Creators", href: "/claude-for/creators/" },
];
---

<Layout
  title="Claudient — the Claude Code knowledge base"
  description={`${stats.skills} skills, ${stats.agents} agents, ${stats.hooks} hooks, ${stats.mcp} MCP configs for Claude Code. Install in 30 seconds. Open source, MIT licensed.`}
>
  <!-- Hero -->
  <section class="container-page py-20 md:py-28">
    <div class="max-w-3xl">
      <p class="pill mb-6">{stats.skills} skills · {stats.agents} agents · MIT</p>
      <h1 class="text-4xl md:text-6xl font-semibold tracking-tight leading-[1.05]">
        Stop explaining your stack to Claude every session.
      </h1>
      <p class="mt-6 text-lg md:text-xl max-w-2xl" style="color: var(--color-muted);">
        Claudient gives Claude Code instant domain expertise — {stats.skills} skills that activate
        automatically, {stats.agents} specialist agents, hooks, and MCP configs. Install in 30
        seconds, works with any Claude Code project.
      </p>

      <div class="mt-8 flex flex-col sm:flex-row gap-3">
        <code
          class="inline-flex items-center px-4 py-3 rounded-md font-mono text-sm"
          style="background-color: var(--color-bg-elevated); border: 1px solid var(--color-border);"
        >
          <span style="color: var(--color-subtle);">$</span>&nbsp;npx claudient add all
        </code>
        <a href="/install/" class="btn-primary">Get started</a>
      </div>

      <!-- Live stats bar -->
      <div class="mt-12 grid grid-cols-2 sm:grid-cols-4 gap-y-4 gap-x-8 text-sm" style="color: var(--color-muted);">
        <div><a href="/skills/" class="hover:underline"><span class="font-semibold" style="color: var(--color-fg);">{stats.skills}</span> skills</a></div>
        <div><a href="/agents/" class="hover:underline"><span class="font-semibold" style="color: var(--color-fg);">{stats.agents}</span> agents</a></div>
        <div><a href="/hooks/" class="hover:underline"><span class="font-semibold" style="color: var(--color-fg);">{stats.hooks}</span> hooks</a></div>
        <div><a href="/mcp/" class="hover:underline"><span class="font-semibold" style="color: var(--color-fg);">{stats.mcp}</span> MCP configs</a></div>
        <div><a href="/workflows/" class="hover:underline"><span class="font-semibold" style="color: var(--color-fg);">{stats.workflows}</span> workflows</a></div>
        <div><a href="/guides/" class="hover:underline"><span class="font-semibold" style="color: var(--color-fg);">{stats.guides}</span> guides</a></div>
        <div><a href="/prompts/" class="hover:underline"><span class="font-semibold" style="color: var(--color-fg);">{stats.prompts}</span> prompts</a></div>
        <div><a href="/rules/" class="hover:underline"><span class="font-semibold" style="color: var(--color-fg);">{stats.rules}</span> rules</a></div>
      </div>
    </div>
  </section>

  <!-- Categories -->
  <section class="container-page pb-24">
    <div class="flex items-end justify-between mb-8">
      <h2 class="text-2xl md:text-3xl font-semibold tracking-tight">
        Browse by category
      </h2>
      <a href="/skills/" class="text-sm hover:underline" style="color: var(--color-muted);">
        All categories →
      </a>
    </div>

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
      {
        categories.map((cat) => (
          <a href={cat.href} class="card p-5 block group">
            <div class="flex items-center justify-between mb-2">
              <h3 class="font-semibold text-base">{cat.name}</h3>
              <span
                class="text-xs font-medium"
                style="color: var(--color-accent);"
              >
                {cat.count}
              </span>
            </div>
            <p class="text-sm" style="color: var(--color-muted);">
              {cat.description}
            </p>
          </a>
        ))
      }
    </div>
  </section>

  <!-- Most popular -->
  <section class="container-page pb-24">
    <div class="flex items-end justify-between mb-8">
      <h2 class="text-2xl md:text-3xl font-semibold tracking-tight">
        Most popular
      </h2>
    </div>

    <div class="grid gap-8 md:grid-cols-3">
      <!-- Popular Skills -->
      <div>
        <h3 class="text-base font-semibold mb-4 flex items-center gap-2">
          <a href="/skills/" class="hover:underline">Skills</a>
          <span class="text-xs font-normal" style="color: var(--color-muted);">→</span>
        </h3>
        <div class="flex flex-col gap-3">
          {featuredSkills.map((item) => (
            <a href={item.href} class="card p-4 block group">
              <div class="font-medium text-sm">{item.title}</div>
              {item.description && (
                <p class="text-xs mt-1 line-clamp-2" style="color: var(--color-muted);">{item.description}</p>
              )}
            </a>
          ))}
        </div>
      </div>

      <!-- Popular Agents -->
      <div>
        <h3 class="text-base font-semibold mb-4 flex items-center gap-2">
          <a href="/agents/" class="hover:underline">Agents</a>
          <span class="text-xs font-normal" style="color: var(--color-muted);">→</span>
        </h3>
        <div class="flex flex-col gap-3">
          {featuredAgents.map((item) => (
            <a href={item.href} class="card p-4 block group">
              <div class="font-medium text-sm">{item.title}</div>
              {item.description && (
                <p class="text-xs mt-1 line-clamp-2" style="color: var(--color-muted);">{item.description}</p>
              )}
            </a>
          ))}
        </div>
      </div>

      <!-- Popular MCP -->
      <div>
        <h3 class="text-base font-semibold mb-4 flex items-center gap-2">
          <a href="/mcp/" class="hover:underline">MCP Servers</a>
          <span class="text-xs font-normal" style="color: var(--color-muted);">→</span>
        </h3>
        <div class="flex flex-col gap-3">
          {featuredMcp.map((item) => (
            <a href={item.href} class="card p-4 block group">
              <div class="font-medium text-sm">{item.title}</div>
              {item.description && (
                <p class="text-xs mt-1 line-clamp-2" style="color: var(--color-muted);">{item.description}</p>
              )}
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Browse by use case -->
  <section
    class="border-y"
    style="background-color: var(--color-bg-elevated); border-color: var(--color-border);"
  >
    <div class="container-page py-16">
      <h2 class="text-2xl md:text-3xl font-semibold tracking-tight mb-8">
        Browse by use case
      </h2>
      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
        {[
          { label: "I run a small business", href: "/claude-for/small-business/" },
          { label: "I'm a solopreneur", href: "/claude-for/solopreneurs/" },
          { label: "I run an ecommerce store", href: "/claude-for/ecommerce/" },
          { label: "I coach or consult", href: "/claude-for/coaches-consultants/" },
          { label: "I'm a developer building with Claude", href: "/skills/ai-engineering/" },
          { label: "I run dev infrastructure", href: "/skills/devops-infra/" },
          { label: "I work in legal", href: "/skills/legal/" },
          { label: "I work in finance", href: "/skills/finance/" },
        ].map((uc) => (
          <a
            href={uc.href}
            class="card p-5 flex items-center justify-between gap-3 group"
          >
            <span class="text-sm font-medium">{uc.label}</span>
            <span class="text-base shrink-0" style="color: var(--color-accent);">→</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Claude for vertical -->
  <section class="container-page py-16">
    <h2 class="text-2xl md:text-3xl font-semibold tracking-tight">
      Claude for your business
    </h2>
    <p class="mt-3 max-w-2xl" style="color: var(--color-muted);">
      Plain-English workflows for small business owners and operators — no
      terminal required. Built for the tools you already pay for: QuickBooks,
      HubSpot, Shopify, and the rest.
    </p>

    <div class="mt-8 flex flex-wrap gap-2">
      {
        claudeForVerticals.map((v) => (
          <a
            href={v.href}
            class="inline-flex items-center px-4 py-2 rounded-full text-sm font-medium border transition-colors hover:bg-[var(--color-bg-elevated)]"
            style="background-color: var(--color-bg); border-color: var(--color-border);"
          >
            {v.label} →
          </a>
        ))
      }
    </div>
  </section>

  <!-- How it works -->
  <section
    class="border-t"
    style="border-color: var(--color-border);"
  >
    <div class="container-page py-20">
      <h2 class="text-2xl md:text-3xl font-semibold tracking-tight mb-10">
        How it works
      </h2>
      <div class="grid gap-8 md:grid-cols-3">
        <div>
          <div
            class="inline-flex items-center justify-center w-9 h-9 rounded-md mb-4 text-sm font-semibold"
            style="background-color: var(--color-accent-soft); color: var(--color-accent);"
          >
            1
          </div>
          <h3 class="font-semibold mb-2">Install with npx</h3>
          <p class="text-sm" style="color: var(--color-muted);">
            One command installs the skills, agents, hooks, and MCP configs you
            need into your Claude Code environment.
          </p>
        </div>
        <div>
          <div
            class="inline-flex items-center justify-center w-9 h-9 rounded-md mb-4 text-sm font-semibold"
            style="background-color: var(--color-accent-soft); color: var(--color-accent);"
          >
            2
          </div>
          <h3 class="font-semibold mb-2">Claude knows your domain</h3>
          <p class="text-sm" style="color: var(--color-muted);">
            Skills activate automatically based on what you're working on. Agents
            spawn when their expertise is needed. Hooks run on the right events.
          </p>
        </div>
        <div>
          <div
            class="inline-flex items-center justify-center w-9 h-9 rounded-md mb-4 text-sm font-semibold"
            style="background-color: var(--color-accent-soft); color: var(--color-accent);"
          >
            3
          </div>
          <h3 class="font-semibold mb-2">Ship faster</h3>
          <p class="text-sm" style="color: var(--color-muted);">
            Less explaining, more building. The drop-ins work in any Claude Code
            project and can be composed with anything you already have.
          </p>
        </div>
      </div>
    </div>
  </section>
</Layout>
