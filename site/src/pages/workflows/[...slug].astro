---
import { getCollection, render } from "astro:content";
import DocLayout from "../../layouts/DocLayout.astro";
import { pathToParts, titleFromEntry, descriptionFromEntry } from "../../lib/content";

export async function getStaticPaths() {
  const entries = await getCollection("workflows", ({ data }) => !data.draft);
  return entries.map((entry) => {
    const { path } = pathToParts(entry.id);
    return { params: { slug: path }, props: { entry } };
  });
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const title = titleFromEntry(entry);
const description = descriptionFromEntry(entry);
---

<DocLayout
  title={title}
  description={description}
  collection="workflows"
  collectionLabel="Workflow"
>
  <Content />
</DocLayout>
