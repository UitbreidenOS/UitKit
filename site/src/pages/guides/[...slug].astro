---
import { getCollection, render } from "astro:content";
import DocLayout from "../../layouts/DocLayout.astro";
import { pathToParts, titleFromEntry, descriptionFromEntry, urlForEntry } from "../../lib/content";
import { buildJsonLd } from "../../lib/seo";

export async function getStaticPaths() {
  const entries = await getCollection("guides", ({ data }) => !data.draft);
  return entries
    .filter((entry) => !entry.id.replace(/\.md$/, "").startsWith("claude-for-"))
    .map((entry) => {
      const { path } = pathToParts(entry.id);
      return { params: { slug: path }, props: { entry } };
    });
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const title = titleFromEntry(entry);
const description = descriptionFromEntry(entry);
const jsonLd = buildJsonLd({ collection: "guides", title, description, url: urlForEntry("guides", entry) });
---

<DocLayout
  title={title}
  description={description}
  collection="guides"
  collectionLabel="Guide"
  jsonLd={jsonLd}
>
  <Content />
</DocLayout>
