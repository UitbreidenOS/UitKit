---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Enterprise — Claudient" description="Claudient Enterprise: pricing tiers, SOC2/GDPR/EU-AI-Act compliance frameworks, governance features, and settings templates. 447 skills, 206 agents, dedicated support.">

<!-- Override body overflow for scrollable enterprise page -->
<style is:global>
  body { overflow: auto !important; }
  html { overflow: auto !important; }
</style>

<!-- Navigation -->
<nav class="sticky top-0 z-50 flex items-center gap-2 h-14 px-6 bg-cream/95 backdrop-blur border-b border-hairline">
  <a href="/" class="flex items-center gap-2 hover:opacity-80 transition">
    <span class="size-7 grid place-items-center rounded-md bg-gradient-to-br from-brand-orange to-brand-red text-white text-[12px] font-extrabold">C</span>
    <span class="text-[15px] font-extrabold text-ink">Claudient</span>
  </a>
  <span class="text-[13px] font-semibold text-mute ml-2">Enterprise</span>
  <div class="ml-auto flex items-center gap-4">
    <a href="/" class="text-[13px] font-semibold text-body hover:text-ink transition">Home</a>
    <a href="https://github.com/Claudient/Claudient" target="_blank" rel="noopener noreferrer" class="text-[13px] font-semibold text-body hover:text-ink transition">GitHub</a>
    <a href="mailto:ceo@uitbreiden.com" class="rounded-md bg-brand-yellow px-4 py-1.5 text-[12px] font-bold text-ink border-b-2 border-[#c79700] hover:brightness-105 transition">
      Contact Sales
    </a>
  </div>
</nav>

<!-- Hero -->
<section class="text-center px-6 pt-16 pb-10 bg-canvas">
  <p class="text-[12px] font-bold uppercase tracking-widest text-brand-purple mb-3">Enterprise Plans & Pricing</p>
  <h1 class="text-4xl sm:text-5xl font-extrabold text-ink max-w-2xl mx-auto leading-tight">
    Open source is always free.
    <br class="hidden sm:block" />
    <span class="text-brand-orange">Scale when you're ready.</span>
  </h1>
  <p class="mt-4 text-[15px] text-mute max-w-xl mx-auto leading-relaxed">
    400+ skills, 190+ agents, 50 workspace stacks, 41 MCP configs — all free under AGPL-3.0.
    Paid tiers add private stacks, governance, compliance, and dedicated support.
  </p>
  <div class="mt-5 flex items-center justify-center gap-3 text-[12px] font-semibold text-mute">
    <span class="flex items-center gap-1"><span class="text-[#3fb950]">✓</span> No credit card required</span>
    <span class="flex items-center gap-1"><span class="text-[#3fb950]">✓</span> Cancel anytime</span>
    <span class="flex items-center gap-1"><span class="text-[#3fb950]">✓</span> Open source always free</span>
  </div>
</section>

<!-- Enterprise Pricing Cards -->
<section class="px-6 py-12 bg-canvas">
  <div class="max-w-6xl mx-auto grid sm:grid-cols-2 lg:grid-cols-4 gap-4">

    <!-- Community -->
    <div class="rounded-2xl border border-hairline bg-white p-6 flex flex-col">
      <span class="inline-flex items-center rounded-full px-3 py-1 text-[11px] font-bold text-white bg-[#3fb950] w-fit">Community</span>
      <div class="mt-4 text-3xl font-extrabold text-ink">Free</div>
      <div class="text-[12px] text-mute mt-1">Forever. No credit card.</div>
      <p class="mt-3 text-[13px] text-body leading-relaxed">Best for individual developers, students, small teams, and open-source projects.</p>
      <ul class="mt-5 space-y-2 text-[12px] text-body flex-1">
        <li class="flex items-start gap-2"><span class="text-[#3fb950] mt-0.5">✓</span> 400+ skills (all public)</li>
        <li class="flex items-start gap-2"><span class="text-[#3fb950] mt-0.5">✓</span> 190+ agents</li>
        <li class="flex items-start gap-2"><span class="text-[#3fb950] mt-0.5">✓</span> 50 workspace stacks</li>
        <li class="flex items-start gap-2"><span class="text-[#3fb950] mt-0.5">✓</span> 41 MCP configs</li>
        <li class="flex items-start gap-2"><span class="text-[#3fb950] mt-0.5">✓</span> 5 languages (EN/FR/DE/ES/NL)</li>
        <li class="flex items-start gap-2"><span class="text-[#3fb950] mt-0.5">✓</span> Install via npm or plugin</li>
        <li class="flex items-start gap-2"><span class="text-[#3fb950] mt-0.5">✓</span> Community support (Discord/GitHub)</li>
      </ul>
      <a href="/" class="mt-6 block text-center rounded-md border border-olive/60 bg-white px-4 py-2.5 text-[13px] font-bold text-ink hover:bg-cream transition">
        Get Started — Free
      </a>
    </div>

    <!-- Team (Most Popular) -->
    <div class="rounded-2xl border-2 border-brand-yellow bg-white p-6 flex flex-col relative">
      <span class="absolute -top-3 left-6 rounded-full bg-brand-yellow px-3 py-1 text-[10px] font-bold uppercase tracking-wide text-ink">Most Popular</span>
      <span class="inline-flex items-center rounded-full px-3 py-1 text-[11px] font-bold text-white bg-[#1d4aff] w-fit">Team</span>
      <div class="mt-4 text-3xl font-extrabold text-ink">$15–25</div>
      <div class="text-[12px] text-mute mt-1">per seat / month (annual billing)</div>
      <p class="mt-3 text-[13px] text-body leading-relaxed">Best for teams 5–50, agencies, and early-stage startups scaling Claude Code adoption.</p>
      <ul class="mt-5 space-y-2 text-[12px] text-body flex-1">
        <li class="flex items-start gap-2"><span class="text-[#3fb950] mt-0.5">✓</span> Everything in Community</li>
        <li class="flex items-start gap-2"><span class="text-[#3fb950] mt-0.5">✓</span> Private stack hosting</li>
        <li class="flex items-start gap-2"><span class="text-[#3fb950] mt-0.5">✓</span> Weekly auto-updates via CLI</li>
        <li class="flex items-start gap-2"><span class="text-[#3fb950] mt-0.5">✓</span> Priority feature requests</li>
        <li class="flex items-start gap-2"><span class="text-[#3fb950] mt-0.5">✓</span> Localized packs per team</li>
        <li class="flex items-start gap-2"><span class="text-[#3fb950] mt-0.5">✓</span> Basic usage statistics</li>
        <li class="flex items-start gap-2"><span class="text-[#3fb950] mt-0.5">✓</span> Email support (24h response)</li>
        <li class="flex items-start gap-2"><span class="text-[#3fb950] mt-0.5">✓</span> 14-day free trial</li>
      </ul>
      <a href="https://github.com/Claudient/Claudient" target="_blank" rel="noopener noreferrer" class="mt-6 block text-center rounded-md bg-brand-yellow px-4 py-2.5 text-[13px] font-bold text-ink border-b-2 border-[#c79700] hover:brightness-105 transition">
        Start Free Trial
      </a>
    </div>

    <!-- Business -->
    <div class="rounded-2xl border border-hairline bg-white p-6 flex flex-col">
      <span class="inline-flex items-center rounded-full px-3 py-1 text-[11px] font-bold text-white bg-[#f5b800] w-fit">Business</span>
      <div class="mt-4 text-3xl font-extrabold text-ink">Custom</div>
      <div class="text-[12px] text-mute mt-1">Enterprise features for growing teams</div>
      <p class="mt-3 text-[13px] text-body leading-relaxed">Best for teams 50–250, companies standardizing across departments, regulated industries.</p>
      <ul class="mt-5 space-y-2 text-[12px] text-body flex-1">
        <li class="flex items-start gap-2"><span class="text-[#3fb950] mt-0.5">✓</span> Everything in Team</li>
        <li class="flex items-start gap-2"><span class="text-[#3fb950] mt-0.5">✓</span> Certified marketplace access</li>
        <li class="flex items-start gap-2"><span class="text-[#3fb950] mt-0.5">✓</span> Governance & audit hooks</li>
        <li class="flex items-start gap-2"><span class="text-[#3fb950] mt-0.5">✓</span> SSO (SAML/OAuth)</li>
        <li class="flex items-start gap-2"><span class="text-[#3fb950] mt-0.5">✓</span> Usage analytics dashboard</li>
        <li class="flex items-start gap-2"><span class="text-[#3fb950] mt-0.5">✓</span> Custom domain stacks</li>
        <li class="flex items-start gap-2"><span class="text-[#3fb950] mt-0.5">✓</span> SOC2-ready compliance stacks</li>
        <li class="flex items-start gap-2"><span class="text-[#3fb950] mt-0.5">✓</span> Slack support (2h response)</li>
        <li class="flex items-start gap-2"><span class="text-[#3fb950] mt-0.5">✓</span> 99.5% SLA</li>
      </ul>
      <a href="mailto:ceo@uitbreiden.com" class="mt-6 block text-center rounded-md bg-brand-blue px-4 py-2.5 text-[13px] font-bold text-white hover:bg-brand-blue/90 transition">
        Contact Sales
      </a>
    </div>

    <!-- Enterprise -->
    <div class="rounded-2xl border border-hairline bg-white p-6 flex flex-col">
      <span class="inline-flex items-center rounded-full px-3 py-1 text-[11px] font-bold text-white bg-[#b62ad9] w-fit">Enterprise</span>
      <div class="mt-4 text-3xl font-extrabold text-ink">Annual</div>
      <div class="text-[12px] text-mute mt-1">Full platform + compliance + dedicated</div>
      <p class="mt-3 text-[13px] text-body leading-relaxed">Best for enterprises 250+, heavily regulated, multi-geography, building on Claudient as platform.</p>
      <ul class="mt-5 space-y-2 text-[12px] text-body flex-1">
        <li class="flex items-start gap-2"><span class="text-[#3fb950] mt-0.5">✓</span> Everything in Business</li>
        <li class="flex items-start gap-2"><span class="text-[#3fb950] mt-0.5">✓</span> Self-hosted / VPC deployment</li>
        <li class="flex items-start gap-2"><span class="text-[#3fb950] mt-0.5">✓</span> SOC2 + GDPR + EU-AI-Act stacks</li>
        <li class="flex items-start gap-2"><span class="text-[#3fb950] mt-0.5">✓</span> Unlimited custom domain stacks</li>
        <li class="flex items-start gap-2"><span class="text-[#3fb950] mt-0.5">✓</span> Custom integrations (Jira, Slack, SF)</li>
        <li class="flex items-start gap-2"><span class="text-[#3fb950] mt-0.5">✓</span> Dedicated stack engineer</li>
        <li class="flex items-start gap-2"><span class="text-[#3fb950] mt-0.5">✓</span> On-site training & workshops</li>
        <li class="flex items-start gap-2"><span class="text-[#3fb950] mt-0.5">✓</span> White-label option</li>
        <li class="flex items-start gap-2"><span class="text-[#3fb950] mt-0.5">✓</span> 99.9% SLA + custom contract</li>
      </ul>
      <a href="mailto:ceo@uitbreiden.com" class="mt-6 block text-center rounded-md bg-brand-purple px-4 py-2.5 text-[13px] font-bold text-white hover:bg-brand-purple/90 transition">
        Schedule Executive Brief
      </a>
    </div>

  </div>
</section>

<!-- Choose the Right Path -->
<section class="px-6 py-12 bg-cream border-t border-hairline">
  <div class="max-w-4xl mx-auto">
    <h2 class="text-2xl font-extrabold text-ink text-center">Choose the right path</h2>
    <div class="mt-8 grid sm:grid-cols-2 gap-4">
      <div class="rounded-xl border border-hairline bg-white p-5">
        <div class="text-[13px] font-bold text-[#3fb950]">Stay on Community if…</div>
        <p class="mt-2 text-[12px] text-body leading-relaxed">You're an individual developer, student, or small team working on open-source projects. All 400+ skills are free, no time limit, no credit card.</p>
      </div>
      <div class="rounded-xl border-2 border-brand-yellow bg-white p-5">
        <div class="text-[13px] font-bold text-[#1d4aff]">Buy Team if…</div>
        <p class="mt-2 text-[12px] text-body leading-relaxed">Your team is 5+ people and needs private stack hosting, weekly auto-updates, and priority support. 14-day free trial, no commitment.</p>
      </div>
      <div class="rounded-xl border border-hairline bg-white p-5">
        <div class="text-[13px] font-bold text-[#f5b800]">Pick Business if…</div>
        <p class="mt-2 text-[12px] text-body leading-relaxed">You're standardizing Claude Code across 50+ people and need SSO, audit hooks, usage analytics, and compliance stacks (SOC2-ready).</p>
      </div>
      <div class="rounded-xl border border-hairline bg-white p-5">
        <div class="text-[13px] font-bold text-[#b62ad9]">Talk to Enterprise if…</div>
        <p class="mt-2 text-[12px] text-body leading-relaxed">You're in a regulated industry (finance, healthcare, government), need self-hosted/VPC deployment, or require SOC2 + GDPR + EU-AI-Act compliance with a dedicated engineer.</p>
      </div>
    </div>
  </div>
</section>

<!-- Feature Comparison Table -->
<section class="px-6 py-12 bg-canvas border-t border-hairline">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-2xl font-extrabold text-ink text-center">Compare all features</h2>
    <p class="mt-2 text-[13px] text-mute text-center">Full breakdown of what's included in each tier.</p>
    <div class="mt-8 rounded-xl border border-hairline bg-white overflow-hidden overflow-x-auto">
      <table class="w-full text-[12px] min-w-[640px]">
        <thead class="bg-soft border-b border-hairline">
          <tr>
            <th class="text-left px-4 py-3 font-bold text-mute w-[35%]">Feature</th>
            <th class="text-center px-4 py-3 font-bold text-[#3fb950]">Community</th>
            <th class="text-center px-4 py-3 font-bold text-[#1d4aff]">Team</th>
            <th class="text-center px-4 py-3 font-bold text-[#f5b800]">Business</th>
            <th class="text-center px-4 py-3 font-bold text-[#b62ad9]">Enterprise</th>
          </tr>
        </thead>
        <tbody class="text-body">
          <tr class="border-b border-hairline"><td class="px-4 py-2.5 font-semibold text-ink">Price</td><td class="px-4 py-2.5 text-center">Free</td><td class="px-4 py-2.5 text-center">$15–25/seat/mo</td><td class="px-4 py-2.5 text-center">Custom</td><td class="px-4 py-2.5 text-center">Annual contract</td></tr>
          <tr class="border-b border-hairline bg-soft/30"><td class="px-4 py-2.5 font-semibold text-ink">Skills</td><td class="px-4 py-2.5 text-center">400+ (public)</td><td class="px-4 py-2.5 text-center">400+</td><td class="px-4 py-2.5 text-center">400+</td><td class="px-4 py-2.5 text-center">400+</td></tr>
          <tr class="border-b border-hairline"><td class="px-4 py-2.5 font-semibold text-ink">Agents</td><td class="px-4 py-2.5 text-center">190+</td><td class="px-4 py-2.5 text-center">190+</td><td class="px-4 py-2.5 text-center">190+</td><td class="px-4 py-2.5 text-center">190+</td></tr>
          <tr class="border-b border-hairline bg-soft/30"><td class="px-4 py-2.5 font-semibold text-ink">Private stacks</td><td class="px-4 py-2.5 text-center text-mute">—</td><td class="px-4 py-2.5 text-center text-[#3fb950]">✓</td><td class="px-4 py-2.5 text-center text-[#3fb950]">✓</td><td class="px-4 py-2.5 text-center text-[#3fb950]">✓</td></tr>
          <tr class="border-b border-hairline"><td class="px-4 py-2.5 font-semibold text-ink">Update frequency</td><td class="px-4 py-2.5 text-center">Auto (public)</td><td class="px-4 py-2.5 text-center">Weekly via CLI</td><td class="px-4 py-2.5 text-center">Weekly via platform</td><td class="px-4 py-2.5 text-center">Custom SLA</td></tr>
          <tr class="border-b border-hairline bg-soft/30"><td class="px-4 py-2.5 font-semibold text-ink">Priority requests</td><td class="px-4 py-2.5 text-center">Community</td><td class="px-4 py-2.5 text-center">High</td><td class="px-4 py-2.5 text-center">Critical</td><td class="px-4 py-2.5 text-center">VIP</td></tr>
          <tr class="border-b border-hairline"><td class="px-4 py-2.5 font-semibold text-ink">Languages</td><td class="px-4 py-2.5 text-center">EN/FR/DE/ES/NL</td><td class="px-4 py-2.5 text-center">EN/FR/DE/ES/NL</td><td class="px-4 py-2.5 text-center">EN/FR/DE/ES/NL</td><td class="px-4 py-2.5 text-center">+ Custom packs</td></tr>
          <tr class="border-b border-hairline bg-soft/30"><td class="px-4 py-2.5 font-semibold text-ink">Governance hooks</td><td class="px-4 py-2.5 text-center">Basic</td><td class="px-4 py-2.5 text-center">Standard</td><td class="px-4 py-2.5 text-center">Advanced + SSO</td><td class="px-4 py-2.5 text-center">Full audit + VPC</td></tr>
          <tr class="border-b border-hairline"><td class="px-4 py-2.5 font-semibold text-ink">Compliance stacks</td><td class="px-4 py-2.5 text-center text-mute">Coming soon</td><td class="px-4 py-2.5 text-center text-mute">Coming soon</td><td class="px-4 py-2.5 text-center">SOC2-ready</td><td class="px-4 py-2.5 text-center">SOC2 + GDPR + EU-AI-Act</td></tr>
          <tr class="border-b border-hairline bg-soft/30"><td class="px-4 py-2.5 font-semibold text-ink">Custom domain stacks</td><td class="px-4 py-2.5 text-center text-mute">—</td><td class="px-4 py-2.5 text-center">Limited</td><td class="px-4 py-2.5 text-center text-[#3fb950]">✓</td><td class="px-4 py-2.5 text-center">Unlimited</td></tr>
          <tr class="border-b border-hairline"><td class="px-4 py-2.5 font-semibold text-ink">Usage analytics</td><td class="px-4 py-2.5 text-center text-mute">—</td><td class="px-4 py-2.5 text-center">Basic</td><td class="px-4 py-2.5 text-center">Dashboard</td><td class="px-4 py-2.5 text-center">Real-time + custom</td></tr>
          <tr class="border-b border-hairline bg-soft/30"><td class="px-4 py-2.5 font-semibold text-ink">Marketplace access</td><td class="px-4 py-2.5 text-center">Free only</td><td class="px-4 py-2.5 text-center">Free + paid</td><td class="px-4 py-2.5 text-center">Certified</td><td class="px-4 py-2.5 text-center">Certified + white-label</td></tr>
          <tr class="border-b border-hairline"><td class="px-4 py-2.5 font-semibold text-ink">Self-hosted / VPC</td><td class="px-4 py-2.5 text-center text-mute">—</td><td class="px-4 py-2.5 text-center text-mute">—</td><td class="px-4 py-2.5 text-center text-mute">—</td><td class="px-4 py-2.5 text-center text-[#3fb950]">✓</td></tr>
          <tr class="border-b border-hairline bg-soft/30"><td class="px-4 py-2.5 font-semibold text-ink">Dedicated engineer</td><td class="px-4 py-2.5 text-center text-mute">—</td><td class="px-4 py-2.5 text-center text-mute">—</td><td class="px-4 py-2.5 text-center text-mute">—</td><td class="px-4 py-2.5 text-center text-[#3fb950]">✓</td></tr>
          <tr class="border-b border-hairline"><td class="px-4 py-2.5 font-semibold text-ink">On-site training</td><td class="px-4 py-2.5 text-center text-mute">—</td><td class="px-4 py-2.5 text-center text-mute">—</td><td class="px-4 py-2.5 text-center text-mute">—</td><td class="px-4 py-2.5 text-center text-[#3fb950]">✓</td></tr>
          <tr><td class="px-4 py-2.5 font-semibold text-ink">Support & SLA</td><td class="px-4 py-2.5 text-center">Community</td><td class="px-4 py-2.5 text-center">Email (24h)</td><td class="px-4 py-2.5 text-center">Slack (2h) + 99.5%</td><td class="px-4 py-2.5 text-center">Dedicated + 99.9%</td></tr>
        </tbody>
      </table>
    </div>
  </div>
</section>

<!-- Compliance Stacks -->
<section class="px-6 py-12 bg-cream border-t border-hairline">
  <div class="max-w-4xl mx-auto">
    <h2 class="text-2xl font-extrabold text-ink text-center">Compliance Stacks</h2>
    <p class="mt-2 text-[13px] text-mute text-center">Pre-audited bundles for regulated industries. Included in Business and Enterprise tiers.</p>
    <div class="mt-8 grid sm:grid-cols-3 gap-4">

      <div class="rounded-xl border border-hairline bg-white p-5">
        <div class="flex items-center gap-2 mb-3">
          <span class="text-2xl">🛡️</span>
          <div>
            <div class="text-[14px] font-bold text-ink">SOC2</div>
            <div class="text-[10px] text-mute">Type II compliance</div>
          </div>
        </div>
        <ul class="space-y-1.5 text-[11px] text-body">
          <li>✓ Access audit skill</li>
          <li>✓ Change log skill</li>
          <li>✓ Security reviewer skill</li>
          <li>✓ Compliance reporter skill</li>
          <li>✓ Audit trail hook (PostToolUse)</li>
          <li>✓ Access control validator (PreToolUse)</li>
          <li>✓ Compliance alert hook (Stop)</li>
        </ul>
        <div class="mt-3 text-[10px] text-mute">Controls: CC6.1, CC6.2, CC7.1, CC7.2</div>
      </div>

      <div class="rounded-xl border border-hairline bg-white p-5">
        <div class="flex items-center gap-2 mb-3">
          <span class="text-2xl">🇪🇺</span>
          <div>
            <div class="text-[14px] font-bold text-ink">GDPR</div>
            <div class="text-[10px] text-mute">EU data governance</div>
          </div>
        </div>
        <ul class="space-y-1.5 text-[11px] text-body">
          <li>✓ Data processing skill</li>
          <li>✓ Consent tracker skill</li>
          <li>✓ Privacy impact assessor</li>
          <li>✓ Data retention policy skill</li>
          <li>✓ Data deletion hook (PreToolUse)</li>
          <li>✓ Consent validator (PostToolUse)</li>
          <li>✓ Data residency enforcer (Stop)</li>
        </ul>
        <div class="mt-3 text-[10px] text-mute">Articles: 5, 6, 17, 32, 35</div>
      </div>

      <div class="rounded-xl border border-hairline bg-white p-5">
        <div class="flex items-center gap-2 mb-3">
          <span class="text-2xl">⚖️</span>
          <div>
            <div class="text-[14px] font-bold text-ink">EU-AI-Act</div>
            <div class="text-[10px] text-mute">AI transparency & risk</div>
          </div>
        </div>
        <ul class="space-y-1.5 text-[11px] text-body">
          <li>✓ High-risk detector skill</li>
          <li>✓ Transparency logger skill</li>
          <li>✓ Human-in-the-loop enforcer</li>
          <li>✓ Bias auditor skill</li>
          <li>✓ Prohibited use blocker (Stop)</li>
          <li>✓ Transparency logger (PostToolUse)</li>
          <li>✓ Risk classification (PreToolUse)</li>
        </ul>
        <div class="mt-3 text-[10px] text-mute">Articles: 5, 6, 13, 14, 26</div>
      </div>

    </div>
    <div class="mt-6 text-center">
      <p class="text-[12px] text-mute">Setup all three at once:</p>
      <code class="mt-1 inline-block rounded-lg bg-code-bg text-code-text px-4 py-2 text-[12px] font-mono">claudient init --enterprise</code>
    </div>
  </div>
</section>

<!-- FAQ -->
<section class="px-6 py-12 bg-canvas border-t border-hairline">
  <div class="max-w-3xl mx-auto">
