      "severity": "WARNING",
      "user_id": "bob@company.com",
      "tool_execution": {
        "tool_name": "search-api",
        "tool_input_hash": "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855",
        "tool_output_hash": "da39a3ee5e6b4b0d3255bfef95601890afd80709",
        "duration_ms": 234,
        "exit_code": 0
      },
      "compliance_flags": {
        "pii_detected": true,
        "policy_violation": false
      },
      "cost_tracking": {
        "cost_usd": 0.003,
        "session_cost_usd": 0.045,
        "cost_category": "api_calls"
      }
    },
    {
      "event_id": "d4c5b6a7-89e0-45f1-2b3c-4d5e6f7a8b9c",
      "session_id": "sess-ghi789",
      "event_timestamp": "2026-06-22T14:32:10.000Z",
      "recorded_at": "2026-06-22T14:32:10.234Z",
      "event_type": "security_violation",
      "severity": "CRITICAL",
      "user_id": "charlie@company.com",
      "compliance_flags": {
        "pii_detected": false,
        "policy_violation": true,
        "rbac_violation": true,
        "suspicious_pattern": true
      },
