  "api": {
    "configureAppService": {
      "signature": "configureAppService(config: Object): AppServiceConfig",
      "returns": "Service configuration with cost estimate"
    },
    "configureContainerInstances": {
      "signature": "configureContainerInstances(config: Object): ContainerConfig",
      "returns": "Service configuration with cost estimate"
    },
    "configureCosmosDb": {
      "signature": "configureCosmosDb(config: Object): CosmosConfig",
      "returns": "Service configuration with cost estimate"
    },
    "configureBlobStorage": {
      "signature": "configureBlobStorage(config: Object): StorageConfig",
      "returns": "Service configuration with cost estimate"
    },
    "generateARMTemplate": {
      "signature": "generateARMTemplate(): Object",
      "returns": "Complete ARM template JSON"
    },
    "validateARMTemplate": {
      "signature": "validateARMTemplate(template: Object): ValidationResult",
      "returns": { "valid": "boolean", "errors": "string[]", "warnings": "string[]" }
    },
    "deploy": {
      "signature": "async deploy(deploymentName: string): Promise<Deployment>",
      "returns": "Deployment result with status, steps, duration"
    },
    "healthCheck": {
      "signature": "async healthCheck(serviceId: string): Promise<HealthCheck>",
      "returns": "Health status with metrics and issues"
    },
    "rollback": {
      "signature": "async rollback(deploymentId: string): Promise<Deployment>",
      "returns": "Rollback result"
    },
    "getDeploymentSummary": {
      "signature": "getDeploymentSummary(deploymentId: string): Object",
      "returns": "Summary with status, duration, services, cost"
    },
    "getResourcesStatus": {
      "signature": "getResourcesStatus(): Array",
      "returns": "Array of deployed resources with status"
    },
    "enableHybridCloud": {
      "signature": "enableHybridCloud(config: Object): Object",
      "returns": "Hybrid cloud configuration"
    }
  },

  "events": [
    {
      "name": "serviceConfigured",
      "payload": { "service": "string", "config": "Object" },
      "description": "Fired when a service is configured"
    },
    {
      "name": "deploymentStarted",
      "payload": { "id": "string", "name": "string", "status": "string" },
      "description": "Fired when deployment begins"
    },
    {
      "name": "deploymentSucceeded",
      "payload": { "id": "string", "status": "succeeded", "duration": "number" },
      "description": "Fired when deployment completes successfully"
    },
    {
      "name": "deploymentFailed",
      "payload": { "id": "string", "error": "string", "status": "failed" },
      "description": "Fired when deployment fails"
    },
    {
      "name": "serviceDeployed",
      "payload": { "id": "string", "name": "string", "resourceId": "string" },
      "description": "Fired when individual service is deployed"
    },
    {
      "name": "healthCheckComplete",
      "payload": { "serviceName": "string", "healthy": "boolean", "metrics": "Object" },
      "description": "Fired when health check completes"
    },
    {
      "name": "rollbackStarted",
      "payload": { "id": "string", "name": "string" },
      "description": "Fired when rollback begins"
    },
    {
      "name": "rollbackCompleted",
      "payload": { "id": "string", "status": "rolled_back" },
      "description": "Fired when rollback completes"
    }
  ],

