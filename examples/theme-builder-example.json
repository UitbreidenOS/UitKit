{
  "name": "Synthwave Neon",
  "description": "80s synthwave inspired theme with magenta and cyan neon colors on dark purple background",
  "version": "1.0.0",
  "type": "dark",
  "author": "theme-builder",
  "license": "MIT",
  "colors": {
    "primary": "#ff00ff",
    "primaryLight": "#ff33ff",
    "primaryDark": "#cc00cc",
    "secondary": "#00ffff",
    "background": "#0d0221",
    "surface": "#1a0a2e",
    "surfaceLight": "#2d1b4e",
    "surfaceDark": "#08010f",
    "text": "#ff00ff",
    "textSecondary": "#00ffff",
    "textTertiary": "#8800ff",
    "textInverse": "#ffffff",
    "border": "#ff00ff",
    "borderLight": "#cc00cc",
    "borderDark": "#660066",
    "error": "#ff006e",
    "errorLight": "#ff1744",
    "errorDark": "#cc0055",
    "success": "#00ff41",
    "successLight": "#39ff14",
    "successDark": "#00cc33",
    "warning": "#ffd60a",
    "warningLight": "#ffeb3b",
    "warningDark": "#ccaa00",
    "info": "#00ffff",
    "infoLight": "#00e5ff",
    "infoDark": "#0099cc",
    "disabled": "#330033",
    "placeholder": "#660066",
    "overlay": "rgba(0, 0, 0, 0.85)",
    "shadow": "rgba(255, 0, 255, 0.1)",
    "cursor": "#ff00ff",
    "selection": "#ff00ff33",
    "black": "#000000",
    "red": "#ff006e",
    "redDark": "#cc0055",
    "green": "#00ff41",
    "greenDark": "#00cc33",
    "yellow": "#ffd60a",
    "yellowDark": "#ccaa00",
    "blue": "#0099ff",
    "blueDark": "#0077cc",
    "magenta": "#ff00ff",
    "magentaDark": "#cc00cc",
    "cyan": "#00ffff",
    "cyanDark": "#00cccc",
    "white": "#ffffff",
    "brightBlack": "#333333",
    "brightRed": "#ff3366",
    "brightGreen": "#00ff41",
    "brightYellow": "#ffff00",
    "brightBlue": "#00ccff",
    "brightMagenta": "#ff00ff",
    "brightCyan": "#00ffff",
    "brightWhite": "#ffffff"
  },
  "typography": {
    "fontFamily": {
      "mono": "'Courier New', 'Courier', 'IBM Plex Mono', 'Roboto Mono', monospace",
      "sans": "'Monaco', 'Menlo', 'Ubuntu Mono', 'Consolas', monospace"
    },
    "fontSize": {
      "xs": "11px",
      "sm": "12px",
      "base": "13px",
      "lg": "14px",
      "xl": "16px",
      "2xl": "18px",
      "3xl": "24px",
      "4xl": "32px"
    },
    "fontWeight": {
      "light": 300,
      "normal": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700,
      "extrabold": 800
    },
    "lineHeight": {
      "tight": 1.2,
      "normal": 1.5,
      "relaxed": 1.75,
      "loose": 2
    },
    "letterSpacing": {
      "tight": "-0.5px",
      "normal": "0px",
      "wide": "1px",
      "wider": "2px"
    }
  },
  "spacing": {
    "0": "0px",
    "1": "2px",
    "2": "4px",
    "3": "6px",
    "4": "8px",
    "6": "12px",
    "8": "16px",
    "12": "24px",
    "16": "32px",
    "20": "40px",
    "24": "48px",
    "32": "64px"
  },
  "borderRadius": {
    "none": "0px",
    "sm": "2px",
    "base": "4px",
    "md": "6px",
    "lg": "8px",
    "xl": "12px",
    "2xl": "16px",
    "full": "9999px"
  },
  "shadows": {
    "none": "none",
    "sm": "0 1px 2px rgba(255, 0, 255, 0.05)",
    "base": "0 1px 3px rgba(255, 0, 255, 0.1), 0 1px 2px rgba(255, 0, 255, 0.06)",
    "md": "0 4px 6px rgba(255, 0, 255, 0.1), 0 2px 4px rgba(255, 0, 255, 0.06)",
    "lg": "0 10px 15px rgba(255, 0, 255, 0.1), 0 4px 6px rgba(255, 0, 255, 0.05)",
    "xl": "0 20px 25px rgba(255, 0, 255, 0.1), 0 10px 10px rgba(255, 0, 255, 0.04)",
    "2xl": "0 25px 50px rgba(255, 0, 255, 0.15)",
    "glow": "0 0 10px rgba(255, 0, 255, 0.3), 0 0 20px rgba(255, 0, 255, 0.2), inset 0 0 10px rgba(255, 0, 255, 0.1)",
    "glowStrong": "0 0 20px rgba(255, 0, 255, 0.5), 0 0 40px rgba(255, 0, 255, 0.3), inset 0 0 20px rgba(255, 0, 255, 0.15)"
  },
  "effects": {
    "scanlines": {
      "enabled": true,
      "pattern": "repeating-linear-gradient(0deg, rgba(0, 0, 0, 0.15) 0px, rgba(0, 0, 0, 0.15) 1px, transparent 1px, transparent 2px)",
      "opacity": 0.05,
      "animation": "scanline-drift 8s linear infinite"
    },
    "crt": {
      "enabled": false,
      "curvature": "0%",
      "vignette": "radial-gradient(ellipse at center, transparent 0%, rgba(0, 0, 0, 0.3) 100%)",
      "chromatic": "0px"
    },
    "glow": {
      "enabled": true,
      "intensity": "medium",
      "blur": "8px",
      "spread": "2px",
      "color": "#ff00ff"
    },
    "terminal": {
      "cursor": {
        "style": "block",
        "animation": "terminal-blink 1s step-end infinite",
        "color": "#ff00ff"
      },
      "textShadow": "0 0 4px rgba(255, 0, 255, 0.3)"
    }
  },
  "components": {
    "button": {
      "base": {
        "padding": "8px 12px",
        "borderRadius": "4px",
        "fontSize": "13px",
        "fontWeight": 600,
        "fontFamily": "mono",
        "border": "1px solid #ff00ff",
        "cursor": "pointer",
        "transition": "all 0.2s ease",
        "textTransform": "uppercase",
        "letterSpacing": "1px"
      },
      "variants": {
        "primary": {
          "background": "rgba(255, 0, 255, 0.1)",
          "color": "#ff00ff",
          "borderColor": "#ff00ff",
          "boxShadow": "0 0 10px rgba(255, 0, 255, 0.2), inset 0 0 10px rgba(255, 0, 255, 0.05)"
        },
        "primaryHover": {
          "background": "rgba(255, 0, 255, 0.2)",
          "color": "#ff33ff",
          "borderColor": "#ff33ff",
          "boxShadow": "0 0 20px rgba(255, 0, 255, 0.4), inset 0 0 15px rgba(255, 0, 255, 0.1)"
        },
        "primaryActive": {
          "background": "rgba(255, 0, 255, 0.3)",
          "color": "#ff00ff",
          "borderColor": "#ff00ff",
          "boxShadow": "0 0 30px rgba(255, 0, 255, 0.5), inset 0 0 20px rgba(255, 0, 255, 0.15)"
        },
        "secondary": {
          "background": "transparent",
          "color": "#00ffff",
          "borderColor": "#00ffff"
        },
        "ghost": {
          "background": "transparent",
          "color": "#ff00ff",
          "borderColor": "transparent"
        },
        "danger": {
          "background": "rgba(255, 0, 110, 0.1)",
          "color": "#ff006e",
          "borderColor": "#ff006e",
          "boxShadow": "0 0 10px rgba(255, 0, 110, 0.2)"
        }
      },
      "disabled": {
        "opacity": 0.5,
        "cursor": "not-allowed",
        "color": "#330033",
        "borderColor": "#330033",
        "background": "rgba(51, 0, 51, 0.1)"
      }
    },
    "input": {
      "base": {
        "padding": "8px 12px",
        "borderRadius": "4px",
        "fontSize": "13px",
        "fontFamily": "mono",
        "backgroundColor": "#08010f",
        "color": "#ff00ff",
        "border": "1px solid #cc00cc",
        "transition": "all 0.2s ease",
        "boxShadow": "inset 0 0 8px rgba(0, 0, 0, 0.5)"
      },
      "focus": {
        "borderColor": "#ff00ff",
        "boxShadow": "0 0 15px rgba(255, 0, 255, 0.3), inset 0 0 10px rgba(255, 0, 255, 0.05)",
        "outline": "none"
      },
      "placeholder": {
        "color": "#660066"
      },
      "disabled": {
        "backgroundColor": "#2d1b4e",
        "color": "#330033",
        "borderColor": "#330033",
        "cursor": "not-allowed",
        "opacity": 0.6
      }
    },
    "card": {
      "base": {
        "backgroundColor": "#1a0a2e",
        "borderRadius": "4px",
        "border": "1px solid rgba(255, 0, 255, 0.2)",
        "padding": "16px",
        "boxShadow": "0 0 15px rgba(255, 0, 255, 0.1), inset 0 0 15px rgba(255, 0, 255, 0.02)"
      },
      "hover": {
        "borderColor": "rgba(255, 0, 255, 0.4)",
        "boxShadow": "0 0 25px rgba(255, 0, 255, 0.15), inset 0 0 20px rgba(255, 0, 255, 0.03)"
      },
      "elevated": {
        "boxShadow": "0 0 30px rgba(255, 0, 255, 0.2), inset 0 0 20px rgba(255, 0, 255, 0.05)"
      }
    },
    "codeBlock": {
      "background": "#08010f",
      "color": "#ff00ff",
      "borderRadius": "4px",
      "border": "1px solid rgba(255, 0, 255, 0.15)",
      "padding": "12px",
      "fontFamily": "mono",
      "fontSize": "12px",
      "lineHeight": 1.6,
      "boxShadow": "inset 0 0 10px rgba(0, 0, 0, 0.5), 0 0 10px rgba(255, 0, 255, 0.1)",
      "overflowX": "auto",
      "textShadow": "0 0 2px rgba(255, 0, 255, 0.2)"
    },
    "badge": {
      "base": {
        "display": "inline-block",
        "padding": "4px 8px",
        "borderRadius": "2px",
        "fontSize": "11px",
        "fontWeight": 600,
        "fontFamily": "mono",
        "letterSpacing": "0.5px",
        "textTransform": "uppercase"
      },
      "success": {
        "backgroundColor": "rgba(0, 255, 65, 0.2)",
        "color": "#00ff41",
        "border": "1px solid #00ff41"
      },
      "error": {
        "backgroundColor": "rgba(255, 0, 110, 0.2)",
        "color": "#ff006e",
        "border": "1px solid #ff006e"
      },
      "warning": {
        "backgroundColor": "rgba(255, 214, 10, 0.2)",
        "color": "#ffd60a",
        "border": "1px solid #ffd60a"
      },
      "info": {
        "backgroundColor": "rgba(0, 255, 255, 0.2)",
        "color": "#00ffff",
        "border": "1px solid #00ffff"
      }
    },
    "dropdown": {
      "background": "#1a0a2e",
      "border": "1px solid #cc00cc",
      "borderRadius": "4px",
      "boxShadow": "0 10px 30px rgba(0, 0, 0, 0.6), 0 0 20px rgba(255, 0, 255, 0.1)",
      "item": {
        "padding": "8px 12px",
        "color": "#ff00ff",
        "hover": {
          "backgroundColor": "rgba(255, 0, 255, 0.1)",
          "color": "#ff33ff"
        }
      }
    },
    "modal": {
      "overlay": "rgba(0, 0, 0, 0.9)",
      "background": "#1a0a2e",
      "border": "2px solid #ff00ff",
      "borderRadius": "4px",
      "boxShadow": "0 0 50px rgba(255, 0, 255, 0.3), 0 0 100px rgba(255, 0, 255, 0.1)"
    },
    "tooltip": {
      "background": "rgba(0, 0, 0, 0.95)",
      "color": "#ff00ff",
      "border": "1px solid #cc00cc",
      "borderRadius": "2px",
      "padding": "6px 8px",
      "fontSize": "12px",
      "fontFamily": "mono",
      "boxShadow": "0 0 15px rgba(255, 0, 255, 0.2)"
    },
    "divider": {
      "color": "rgba(255, 0, 255, 0.1)",
      "thickness": "1px"
    }
  },
  "animations": {
    "scanlineDrift": {
      "name": "scanline-drift",
      "keyframes": {
        "0%": { "transform": "translateY(0)" },
        "100%": { "transform": "translateY(10px)" }
      },
      "duration": "8s",
      "timingFunction": "linear",
      "iterationCount": "infinite"
    },
    "terminalBlink": {
      "name": "terminal-blink",
      "keyframes": {
        "0%": { "opacity": 1 },
        "49%": { "opacity": 1 },
        "50%": { "opacity": 0 },
        "100%": { "opacity": 0 }
      },
      "duration": "1s",
      "timingFunction": "step-end",
      "iterationCount": "infinite"
    },
    "glitch": {
      "name": "glitch",
      "keyframes": {
        "0%": { "transform": "translate(0)" },
        "20%": { "transform": "translate(-2px, 2px)" },
        "40%": { "transform": "translate(-2px, -2px)" },
        "60%": { "transform": "translate(2px, 2px)" },
        "80%": { "transform": "translate(2px, -2px)" },
        "100%": { "transform": "translate(0)" }
      },
      "duration": "0.4s",
      "timingFunction": "ease-in-out",
      "iterationCount": "1"
    },
    "pulse": {
      "name": "pulse-glow",
      "keyframes": {
        "0%": { "boxShadow": "0 0 10px rgba(255, 0, 255, 0.2)" },
        "50%": { "boxShadow": "0 0 25px rgba(255, 0, 255, 0.4)" },
        "100%": { "boxShadow": "0 0 10px rgba(255, 0, 255, 0.2)" }
      },
      "duration": "2s",
      "timingFunction": "ease-in-out",
      "iterationCount": "infinite"
    },
    "fadeIn": {
      "name": "fade-in-glow",
      "keyframes": {
        "0%": { "opacity": 0, "textShadow": "0 0 0 rgba(255, 0, 255, 0)" },
        "100%": { "opacity": 1, "textShadow": "0 0 4px rgba(255, 0, 255, 0.3)" }
      },
      "duration": "0.5s",
      "timingFunction": "ease-in",
      "iterationCount": "1"
    }
  },
  "states": {
    "hover": {
      "filter": "brightness(1.2)",
      "textShadow": "0 0 8px rgba(255, 0, 255, 0.4)"
    },
    "active": {
      "filter": "brightness(1.4)",
      "textShadow": "0 0 12px rgba(255, 0, 255, 0.6)"
    },
    "focus": {
      "outline": "2px solid #ff00ff",
      "outlineOffset": "2px",
      "boxShadow": "0 0 20px rgba(255, 0, 255, 0.3)"
    },
    "disabled": {
      "opacity": 0.5,
      "cursor": "not-allowed",
      "filter": "grayscale(50%)"
    }
  },
  "darkMode": {
    "enabled": true,
    "overrides": {}
  },
  "breakpoints": {
    "xs": "320px",
    "sm": "640px",
    "md": "768px",
    "lg": "1024px",
    "xl": "1280px",
    "2xl": "1536px"
  },
  "metadata": {
    "lastUpdated": "2026-06-22",
    "production": false,
    "tags": ["custom", "matrix-inspired", "synthwave", "neon", "cyberpunk"],
    "compatibility": {
      "claudeCode": "1.0+",
      "vscode": "1.60+",
      "terminal": "ANSI 24-bit true color",
      "os": ["macOS", "Linux", "Windows (WSL2)"]
    }
  },
  "customization": {
    "changeColors": "Modify colors object to adjust primary magenta/cyan accents",
    "disableScanlines": "Set effects.scanlines.enabled to false for cleaner look",
    "adjustGlow": "Modify effects.glow.blur (smaller = sharper, larger = softer)",
    "enableCRT": "Set effects.crt.enabled to true for curved monitor effect"
  }
}
